{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "STL Browser",
  "version": "0.1.0",
  "identifier": "com.stlbrowser.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "STL Browser",
        "width": 1600,
        "height": 820,
        "minWidth": 1600,
        "minHeight": 820,
        "resizable": true,
        "theme": null
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "copyright": "© 2026 Sebastian Mayer",
    "shortDescription": "Visual preview browser for 3D printing files.",
    "longDescription": "STL Browser is a Photos.app-style visual browser for STL, 3MF, and OBJ files, with live thumbnails and a 3D detail viewer.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "dmg": {
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    }
  }
}
