{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spike 2 — Asset Protocol",
  "version": "0.0.1",
  "identifier": "com.spike.assetprotocol",
  "build": {
    "frontendDist": "./dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Spike 2 — Asset Protocol",
        "width": 900,
        "height": 700
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": false
  }
}
